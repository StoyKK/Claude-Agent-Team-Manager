{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-home-meta-recursive",
    "fs:scope-home-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$HOME/.aui" },
        { "path": "$HOME/.aui/**" },
        { "path": "$HOME/.claude" },
        { "path": "$HOME/.claude/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "log:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "open", "cmd": "open", "args": true }
      ]
    }
  ]
}
